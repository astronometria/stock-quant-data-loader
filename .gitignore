# -------------------------------------------------------------------
# Python cache / build artifacts
# -------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# -------------------------------------------------------------------
# Local developer backups
# -------------------------------------------------------------------
*.bak
*.bak1
*.bak2
*.bak3
*.bak4
*.bak5
*.bak6
*.bak7
*.bak8
*.bak9

# -------------------------------------------------------------------
