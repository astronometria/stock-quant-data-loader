# -------------------------------------------------------------------
.venv/
venv/
env/

# -------------------------------------------------------------------
# Environment files
# -------------------------------------------------------------------
.env
.env.*

# -------------------------------------------------------------------
# Local databases and generated runtime artifacts
# -------------------------------------------------------------------
*.duckdb
*.duckdb.wal
*.duckdb.tmp
data/build/
data/staging/
data/current
data/releases/*
!data/releases/.gitkeep

# -------------------------------------------------------------------
# Logs
# -------------------------------------------------------------------
logs/*
!logs/.gitkeep

