# ============================================================================
# stock-quant-data-loader - .gitignore
# ============================================================================
# Objectif:
# - versionner uniquement le code, le SQL et les petits fichiers utiles
# - exclure les données locales lourdes, builds intermédiaires et artefacts
# - garder un repo propre pour push/pull/review
# ============================================================================

# ============================================================================
# Python bytecode / native build leftovers
# ============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# ============================================================================
# Local developer backups
# Notes:
# - le repo peut contenir des backups locaux pendant le travail
# - ils ne doivent pas être poussés
# ============================================================================
*.bak
*.bak1
*.bak2
*.bak3
*.bak4
*.bak5
*.bak6
*.bak7
*.bak8
*.bak9

# ============================================================================
# Virtual environments
# ============================================================================
.venv/
venv/
env/

# ============================================================================
# Environment files / secrets
# ============================================================================
.env
.env.*

# ============================================================================
# DuckDB / local runtime database artifacts
# Notes:
# - le vrai runtime est local
# - les WAL / tmp ne doivent jamais être commit
# ============================================================================
*.duckdb
*.duckdb.wal
*.duckdb.tmp
*.db
*.sqlite
*.sqlite3

# ============================================================================
# Project data directories
# Notes:
# - staging, build, derived = artefacts générés localement
# - on ne pousse pas les gros JSON/parquet/build intermédiaires
# - current/releases servent au runtime local
# ============================================================================
data/build/
data/staging/
data/derived/
data/current
data/releases/*
!data/releases/.gitkeep

# ============================================================================
# Logs
# Notes:
# - garder seulement le placeholder si présent
# ============================================================================
logs/*
!logs/.gitkeep
*.log

# ============================================================================
# Test / lint / typing / coverage caches
# ============================================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ============================================================================
# Packaging / build artifacts
# ============================================================================
build/
dist/
*.egg-info/

# ============================================================================
# Jupyter / notebook noise
# ============================================================================
.ipynb_checkpoints/

# ============================================================================
# IDE / editor / OS noise
# ============================================================================
.vscode/
.idea/
.DS_Store
Thumbs.db
